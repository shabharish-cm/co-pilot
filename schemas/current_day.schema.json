{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CurrentDay",
  "type": "object",
  "required": ["date", "timezone", "sourceStatus", "openTasks", "completedToday", "dueSoon", "todayMeetings", "digestPaths"],
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "timezone": { "type": "string" },
    "lastMorningSyncAt": { "type": ["string", "null"] },
    "lastEveningSyncAt": { "type": ["string", "null"] },
    "sourceStatus": {
      "type": "object",
      "required": ["todoist", "googleCalendar"],
      "properties": {
        "todoist":       { "type": "string", "enum": ["fresh", "stale", "failed", "missing"] },
        "googleCalendar": { "type": "string", "enum": ["fresh", "stale", "failed", "missing"] }
      }
    },
    "openTasks":      { "type": "array" },
    "completedToday": { "type": "array" },
    "dueSoon":        { "type": "array" },
    "todayMeetings":  { "type": "array" },
    "digestPaths": {
      "type": "object",
      "required": ["morning", "eod"],
      "properties": {
        "morning": { "type": ["string", "null"] },
        "eod":     { "type": ["string", "null"] }
      }
    }
  },
  "additionalProperties": false
}
