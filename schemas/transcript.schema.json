{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedTranscriptFile",
  "type": "object",
  "required": ["dayKey", "generatedAt", "transcripts"],
  "properties": {
    "dayKey":       { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAt":  { "type": "string" },
    "transcripts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["transcriptId", "meetingTitle", "meetingDate", "participants", "summary", "transcriptText", "sourceUrl", "fetchedAt", "sourceDay"],
        "properties": {
          "transcriptId":   { "type": "string" },
          "meetingTitle":   { "type": "string" },
          "meetingDate":    { "type": "string" },
          "participants":   { "type": "array", "items": { "type": "string" } },
          "summary":        { "type": "string" },
          "transcriptText": { "type": "string" },
          "sourceUrl":      { "type": "string" },
          "fetchedAt":      { "type": "string" },
          "sourceDay":      { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
